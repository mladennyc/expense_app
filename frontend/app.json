{
  "expo": {
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow KASA to access your camera to take receipt photos.",
          "photosPermission": "Allow KASA to access your photos to select receipt images."
        }
      ]
    ],
    "name": "KASA",
    "slug": "kasa",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.mladennyc.kasa",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png"
      },
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "packagerOpts": {
      "host": "192.168.1.76"
    },
    "extra": {
      "eas": {
        "projectId": "bbc448be-3959-438f-8cba-51c399b7b65f"
      }
    }
  }
}
